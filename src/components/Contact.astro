---
// Web3Forms access key — get a free one at https://web3forms.com (register it
// to warwil533@gmail.com). Safe to live in client HTML: it can only send to the
// registered inbox, never read anything.
const WEB3FORMS_KEY = "7a1f935d-9a7b-4395-9e28-acedf891e6df";
---
<section class="section contact-section" id="contact">
  <div class="container contact-inner">
    <div class="contact-info">
      <span class="section-label">Contact</span>
      <h2 class="section-heading">Let's work together.</h2>
      <p class="section-sub">
        Tell me what you're working on and I'll get back to you within a day.
        No pressure, no sales pitch. Just a straight answer on what I can do for you.
      </p>
      <div class="contact-details">
        <a href="tel:8439014691" class="contact-link" title="Call me">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          843-901-4691
        </a>
        <a href="mailto:warwil533@gmail.com" class="contact-link" title="Email me">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            <polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="contact-link-text">warwil533@gmail.com</span>
        </a>
        <a href="https://www.linkedin.com/in/william-ward-8a24b33a4/" target="_blank" rel="noopener noreferrer" class="contact-link" title="Connect on LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 110-4.13 2.06 2.06 0 010 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/>
          </svg>
          LinkedIn
        </a>
        <a href="https://www.instagram.com/will.240sx/" target="_blank" rel="noopener noreferrer" class="contact-link" title="Follow on Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.75"/>
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.75"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/>
          </svg>
          Instagram
        </a>
        <a href="https://nextdoor.com/profile/01KfmYx2Xg9G9ywT4" target="_blank" rel="noopener noreferrer" class="contact-link" title="Find me on Nextdoor">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3 11 12 3l9 8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M5 9.5V20h4v-5a3 3 0 016 0v5h4V9.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Nextdoor
        </a>
      </div>
    </div>
    <div class="form-wrap">
    <form class="contact-form" id="contact-form">
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value="New lead from will-ward.com" />
      <input type="hidden" name="from_name" value="Will Ward Website" />
      <input type="checkbox" name="botcheck" class="hidden-honeypot" tabindex="-1" autocomplete="off" />
      <div class="form-row">
        <div class="form-field">
          <label for="name">Your name <span class="required" aria-hidden="true">*</span></label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Jane Smith"
            required
            autocomplete="name"
          />
        </div>
        <div class="form-field">
          <label for="email">Email address <span class="required" aria-hidden="true">*</span></label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="jane@yourbusiness.com"
            required
            autocomplete="email"
          />
        </div>
      </div>
      <div class="form-field">
        <label for="business">Business name</label>
        <input
          type="text"
          id="business"
          name="business"
          placeholder="Smith Plumbing Co."
          autocomplete="organization"
        />
      </div>
      <div class="form-field">
        <label for="message">What do you need? <span class="required" aria-hidden="true">*</span></label>
        <textarea
          id="message"
          name="message"
          rows="4"
          placeholder="Tell me a bit about your business and what you're looking for..."
          required
        ></textarea>
      </div>
      <button type="submit" class="btn btn-primary form-submit">
        <span class="form-submit-label">Send message</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <p class="form-note">I typically respond within 24 hours.</p>
      <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
    </form>
    <div class="form-success" id="form-success" hidden>
      <div class="form-success-icon" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h3>Thanks!</h3>
      <p>Your message is on its way. I'll get back to you within a day.</p>
    </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status');
  const successEl = document.getElementById('form-success');

  if (form) {
    const btn = form.querySelector('.form-submit') as HTMLButtonElement;
    const label = form.querySelector('.form-submit-label');
    const defaultLabel = label?.textContent ?? 'Send message';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (statusEl) { statusEl.textContent = ''; statusEl.className = 'form-status'; }
      btn.disabled = true;
      if (label) label.textContent = 'Sending…';

      const data = Object.fromEntries(new FormData(form));
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (res.ok && json.success) {
          form.hidden = true;
          if (successEl) successEl.hidden = false;
          return;
        }
        throw new Error(json.message || 'Submit failed');
      } catch (err) {
        btn.disabled = false;
        if (label) label.textContent = defaultLabel;
        if (statusEl) {
          statusEl.textContent = 'Something went wrong. Please email warwil533@gmail.com directly.';
          statusEl.className = 'form-status form-status--error';
        }
      }
    });
  }
</script>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1.25fr;
    gap: 4rem;
    align-items: start;
  }
  .form-wrap { min-width: 0; }
  .hidden-honeypot {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
  }
  .form-status {
    text-align: center;
    font-size: 0.8125rem;
    margin: 0;
    max-width: 100%;
  }
  .form-status:empty { display: none; }
  .form-status--error { color: var(--destructive); font-weight: 500; }

  .form-success {
    background: var(--site-surface);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .form-success-icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(34,197,94,0.12);
    color: #16A34A;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
  }
  .form-success h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--site-fg);
  }
  .form-success p {
    font-size: 0.9375rem;
    color: var(--site-secondary);
    max-width: 36ch;
  }
  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    max-width: 100%;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--site-secondary);
    transition: color 150ms;
  }
  .contact-link:hover { color: var(--site-fg); }
  .contact-link svg { flex-shrink: 0; }
  .contact-link-text {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  /* ── Form ── */
  .contact-form {
    background: var(--site-surface);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
    box-shadow: var(--shadow-sm);
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 0;
  }
  label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--site-fg);
  }
  .required { color: var(--site-accent); }
  input, textarea {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--site-fg);
    background: var(--site-bg);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    padding: 0.625rem 0.875rem;
    transition: border-color 150ms, box-shadow 150ms;
    min-height: 44px;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    outline: none;
    resize: vertical;
  }
  input::placeholder, textarea::placeholder {
    color: var(--site-muted);
  }
  input:focus, textarea:focus {
    border-color: var(--site-accent);
    box-shadow: 0 0 0 3px rgba(3,105,161,.12);
  }
  textarea { min-height: 120px; }
  .form-submit {
    width: 100%;
    justify-content: center;
    margin-top: 0.25rem;
  }
  .form-note {
    text-align: center;
    font-size: 0.78125rem;
    color: var(--site-muted);
    max-width: 100%;
  }

  @media (max-width: 800px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
    .contact-form { padding: 1.5rem; }
  }
</style>
