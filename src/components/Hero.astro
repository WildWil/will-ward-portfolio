---
import { HeroCTA } from './HeroCTA';
import { InfiniteGrid } from './ui/InfiniteGrid';
---
<section class="hero section">
  <InfiniteGrid client:load />
  <div class="container hero-inner">
    <div class="hero-content">
      <h1 class="hero-heading">
        Web design and IT services<span class="hero-dot">.</span>
      </h1>
      <HeroCTA client:load />
      <p class="hero-sub">
        I'm Will Ward. I build websites for local businesses and fix computers
        for people in Mount Pleasant, SC.
      </p>
      <div class="hero-actions">
        <a href="#services" class="btn btn-primary">See my services</a>
        <a href="#contact" class="btn btn-outline">Get in touch</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">3–7</span>
          <span class="stat-label">day site turnaround</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">Mt. Pleasant</span>
          <span class="stat-label">SC based</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">Since 2023</span>
          <span class="stat-label">web + IT services</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="browser-frame">
        <div class="browser-bar">
          <div class="browser-dots">
            <span></span><span></span><span></span>
          </div>
          <div class="browser-url">a site I built</div>
        </div>
        <div class="browser-shot">
          <img
            src="/work-plumbing.jpg"
            alt="Bluewater Plumbing website, designed and built by Will Ward"
            width="1440"
            height="900"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
  <a href="#services" class="scroll-cue" aria-label="Scroll to services">
    <span class="scroll-cue-text">Scroll</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    /* Fill the viewport below the 64px sticky header on first load, so the
       next section doesn't peek in at the bottom. Grows if content is taller. */
    min-height: calc(100vh - 64px);
    min-height: calc(100dvh - 64px);
    display: flex;
    align-items: center;
    padding-top: clamp(3rem, 8vw, 5rem);
    padding-bottom: clamp(3rem, 8vw, 5rem);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: center;
  }
  .hero-content {
    min-width: 0;
  }

  /* ── Scroll cue ── */
  .scroll-cue {
    position: absolute;
    bottom: 1.25rem;
    left: 0;
    right: 0;
    margin-inline: auto;
    width: fit-content;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: var(--site-muted);
    transition: color 150ms;
    animation: scroll-bounce 2.2s ease-in-out infinite;
  }
  .scroll-cue:hover { color: var(--site-fg); }
  .scroll-cue-text {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(6px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-cue { animation: none; }
  }

  /* ── Heading ── */
  .hero-heading {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 1.25rem;
    color: var(--site-fg);
  }
  .hero-dot { color: var(--site-accent); }

  .hero-sub {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--site-secondary);
    max-width: 46ch;
    margin-bottom: 2rem;
  }

  /* ── Actions ── */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  /* ── Stats ── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .stat { display: flex; flex-direction: column; gap: 0.125rem; }
  .stat-num {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--site-fg);
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--site-muted);
    font-weight: 500;
  }
  .stat-divider {
    width: 1px;
    height: 28px;
    background: var(--site-border);
  }

  /* ── Browser mockup ── */
  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .browser-frame {
    width: 100%;
    max-width: 440px;
    background: var(--site-surface);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  .browser-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: #F1F5F9;
    border-bottom: 1px solid var(--site-border);
  }
  .browser-dots {
    display: flex;
    gap: 5px;
  }
  .browser-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--site-border);
  }
  .browser-dots span:nth-child(1) { background: #FCA5A5; }
  .browser-dots span:nth-child(2) { background: #FDE68A; }
  .browser-dots span:nth-child(3) { background: #86EFAC; }
  .browser-url {
    flex: 1;
    background: var(--site-surface);
    border: 1px solid var(--site-border);
    border-radius: 6px;
    padding: 0.3rem 0.75rem;
    font-size: 0.75rem;
    color: var(--site-muted);
    font-family: var(--font-body);
  }
  .browser-shot {
    line-height: 0;
  }
  .browser-shot img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 800px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .browser-frame { max-width: 360px; }
    /* Mobile: natural height and let the scroll cue flow in below the work
       image (centered) instead of floating absolutely over it. */
    .hero {
      min-height: auto;
      display: block;
    }
    .scroll-cue {
      position: static;
      bottom: auto;
      margin: 1.75rem auto 0;
    }
  }

  @media (max-width: 480px) {
    .hero-heading { font-size: 2.25rem; }
    .browser-frame { max-width: 100%; }
    /* Keep the three stats on one centered row */
    .hero-stats {
      flex-wrap: nowrap;
      justify-content: center;
      gap: 0.75rem;
    }
    .stat {
      align-items: center;
      text-align: center;
      flex: 1;
      min-width: 0;
    }
    .stat-num { font-size: 0.875rem; }
    .stat-label { font-size: 0.68rem; }
    .stat-divider { height: 26px; }
  }
</style>
