      <a href="https://www.linkedin.com/in/william-ward-8a24b33a4/" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="Will Ward on LinkedIn" title="LinkedIn">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 110-4.13 2.06 2.06 0 010 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/>
        </svg>
      </a>
      <a href="https://www.instagram.com/will.240sx/" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="Will Ward on Instagram" title="Instagram">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.75"/>
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.75"/>
          <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/>
        </svg>
      </a>
      <a href="https://nextdoor.com/profile/01KfmYx2Xg9G9ywT4" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="Will Ward on Nextdoor" title="Nextdoor">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M3 11 12 3l9 8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M5 9.5V20h4v-5a3 3 0 016 0v5h4V9.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
