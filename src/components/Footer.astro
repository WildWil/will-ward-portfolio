      </a>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <span>&copy; {year} Will Ward. All rights reserved.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--site-border);
    background: var(--site-surface);
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 2rem;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .footer-name {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--site-fg);
    letter-spacing: -0.01em;
  }
  .footer-location {
    font-size: 0.75rem;
    color: var(--site-muted);
  }
  .footer-nav {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .footer-nav a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--site-secondary);
    transition: color 150ms;
  }
  .footer-nav a:hover { color: var(--site-fg); }
  .footer-right {
    display: flex;
    gap: 0.75rem;
  }
  .footer-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    color: var(--site-muted);
    transition: color 150ms, background 150ms;
  }
  .footer-link:hover {
    color: var(--site-fg);
    background: var(--site-border);
  }
  .footer-bottom {
    border-top: 1px solid var(--site-border);
    padding-block: 0.875rem;
  }
  .footer-bottom span {
    font-size: 0.75rem;
    color: var(--site-muted);
  }

  @media (max-width: 560px) {
    .footer-nav { display: none; }
  }
</style>
