---
const steps = [
  {
    num: '01',
    title: 'Tell me about your business',
    body: "We chat by text, call, or email. You tell me what you do, who your customers are, and what you need the site to accomplish. I'll ask questions until I have a clear picture.",
  },
  {
    num: '02',
    title: 'I design and build it',
    body: "I put together a custom design and build it from scratch. You get a preview link to review before anything goes live.",
  },
  {
    num: '03',
    title: 'Your site goes live',
    body: "Once you're happy, I launch the site and hand over everything you need: your domain, your files, your login. No lock-in.",
  },
];
---
<section class="section" id="process">
  <div class="container">
    <span class="section-label">Process</span>
    <h2 class="section-heading">How it works</h2>
    <p class="section-sub" style="margin-bottom: 3rem;">
      Simple and straightforward. Most projects are done within a week.
    </p>
    <div class="process-steps">
      {steps.map((step, i) => (
        <div class="process-step">
          <div class="step-num-col">
            <div class="step-num">{step.num}</div>
            {i < steps.length - 1 && <div class="step-line" aria-hidden="true"></div>}
          </div>
          <div class="step-body">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-text">{step.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 640px;
  }
  .process-step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .step-num-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .step-num {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid var(--site-border);
    background: var(--site-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--site-accent);
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }
  .step-line {
    width: 2px;
    flex: 1;
    min-height: 2.5rem;
    background: var(--site-border);
    margin-block: 6px;
  }
  .step-body {
    padding-bottom: 2.5rem;
  }
  .process-step:last-child .step-body {
    padding-bottom: 0;
  }
  .step-title {
    font-size: 1.0625rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }
  .step-text {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--site-secondary);
    max-width: 100%;
  }
</style>
