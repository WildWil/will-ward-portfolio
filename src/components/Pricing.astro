---
const tiers = [
  {
    name: 'Starter',
    price: '$299',
    note: 'one-time',
    desc: 'A clean, professional presence for a new business.',
    features: ['3 pages (Home, About, Contact)', 'Mobile-friendly design', 'Contact info + Google Maps', 'Ready in about 1 week'],
    featured: false,
  },
  {
    name: 'Standard',
    price: '$549',
    note: 'one-time',
    desc: 'More room for services, photos, and getting found on Google.',
    features: ['Up to 5 pages', 'Contact form', 'Photo gallery', 'Basic SEO setup', 'Ready in 1–2 weeks'],
    featured: true,
  },
  {
    name: 'Custom',
    price: '$899+',
    note: 'starting at',
    desc: 'Booking, online store, or custom features built to fit.',
    features: ['Unlimited pages', 'Online booking or store', 'Custom functionality', 'Priority support'],
    featured: false,
  },
];
---
<section class="section pricing-section" id="services">
  <div class="container">
    <div class="pricing-header">
      <span class="section-label">Website Design</span>
      <h2 class="section-heading">Simple pricing. No surprises.</h2>
      <p class="section-sub">
        Flat rates and 50% upfront. You own everything when it's done.
      </p>
    </div>

    <div class="pricing-carousel">
      <button class="pricing-arrow pricing-arrow--prev" id="pricing-prev" type="button" aria-label="Previous plan">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="pricing-grid">
      {tiers.map(t => (
        <div class={`price-card ${t.featured ? 'price-card--featured' : ''}`}>
          {t.featured && <div class="price-badge">Most popular</div>}
          <div class="price-name">{t.name}</div>
          <div class="price-amount">
            <span class="price-value">{t.price}</span>
            <span class="price-note">{t.note}</span>
          </div>
          <p class="price-desc">{t.desc}</p>
          <ul class="price-features">
            {t.features.map(f => (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="#contact" class={`btn ${t.featured ? 'btn-primary' : 'btn-outline'} price-cta`}>
            Get started
          </a>
        </div>
      ))}
      </div>
      <button class="pricing-arrow pricing-arrow--next" id="pricing-next" type="button" aria-label="Next plan">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div class="pricing-dots" id="pricing-dots">
      {tiers.map((_, i) => (
        <button class="pricing-dot" type="button" data-i={i} aria-label={`Go to plan ${i + 1}`}></button>
      ))}
    </div>

    <div class="care-plan">
      <div class="care-left">
        <span class="care-title">Care Plan</span>
        <span class="care-desc">Domain, SSL, small content updates, and ongoing maintenance after launch.</span>
      </div>
      <div class="care-right">
        <span class="care-price">$30<span class="care-per">/mo</span></span>
        <span class="care-optional">optional add-on</span>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    background: var(--site-surface);
    border-top: 1px solid var(--site-border);
    border-bottom: 1px solid var(--site-border);
  }
  .pricing-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .pricing-header .section-sub { text-align: center; }

  .pricing-carousel { position: relative; }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    align-items: stretch;
    max-width: 980px;
    margin-inline: auto;
  }

  /* Prev/next arrows — only shown in carousel (mobile/tablet) mode */
  .pricing-arrow { display: none; }
  .price-card {
    position: relative;
    background: var(--site-bg);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 200ms, transform 200ms;
  }
  .price-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .price-card--featured {
    background: var(--site-fg);
    border-color: var(--site-fg);
    transform: scale(1.03);
  }
  :global(.dark) .price-card--featured {
    background: #0E2236;
    border-color: var(--primary);
  }
  :global(.dark) .price-card--featured .price-cta {
    background: #0284C7;
    color: #fff;
    border-color: #0284C7;
  }
  :global(.dark) .price-card--featured .price-cta:hover {
    background: #0EA5E9;
    border-color: #0EA5E9;
  }
  .price-card--featured:hover { transform: scale(1.03) translateY(-2px); }
  .price-card--featured .price-name { color: rgba(255,255,255,0.6); }
  .price-card--featured .price-value { color: #fff; }
  .price-card--featured .price-note,
  .price-card--featured .price-desc { color: rgba(255,255,255,0.65); }
  .price-card--featured .price-features li { color: rgba(255,255,255,0.8); }

  .price-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--site-accent);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.875rem;
    border-radius: 999px;
    white-space: nowrap;
  }
  .price-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--site-secondary);
    letter-spacing: 0.02em;
  }
  .price-amount {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .price-value {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--site-fg);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .price-note {
    font-size: 0.8125rem;
    color: var(--site-muted);
  }
  .price-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--site-secondary);
    max-width: 100%;
    min-height: 2.5rem;
  }
  .price-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }
  .price-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--site-secondary);
  }
  .price-features svg {
    flex-shrink: 0;
    color: #22c55e;
    margin-top: 1px;
  }
  .price-card--featured .price-features svg { color: #4ade80; }
  .price-cta {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
  }
  /* Solid, high-contrast CTA on the light side cards so it doesn't blend
     into the card background (the grey btn-outline did). */
  .price-card:not(.price-card--featured) .price-cta {
    background: var(--site-fg);
    color: var(--site-bg);
    border-color: var(--site-fg);
  }
  .price-card:not(.price-card--featured) .price-cta:hover {
    background: var(--site-accent);
    border-color: var(--site-accent);
    color: #fff;
  }
  .price-card--featured .price-cta {
    background: #fff;
    color: var(--site-fg);
    border-color: #fff;
  }
  .price-card--featured .price-cta:hover {
    background: #f1f5f9;
    border-color: #f1f5f9;
  }

  /* Care plan add-on */
  .care-plan {
    max-width: 980px;
    margin: 1.25rem auto 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1.25rem 1.75rem;
    background: var(--site-bg);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-lg);
  }
  .care-left { display: flex; flex-direction: column; gap: 0.2rem; }
  .care-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    color: var(--site-fg);
  }
  .care-desc { font-size: 0.875rem; color: var(--site-secondary); }
  .care-right { text-align: right; }
  .care-price {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--site-fg);
    letter-spacing: -0.02em;
  }
  .care-per { font-size: 0.9rem; color: var(--site-muted); font-weight: 500; }
  .care-optional {
    display: block;
    font-size: 0.75rem;
    color: var(--site-muted);
  }

  @media (max-width: 860px) {
    /* Full-bleed centered swipe carousel: each plan snaps to center with a
       peek of the neighbours on both sides. */
    .pricing-grid {
      display: flex;
      max-width: none;
      margin-inline: calc(var(--px) * -1);   /* break out of container padding */
      padding-inline: 9%;                     /* leading/trailing so first & last center */
      gap: 0.875rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scroll-padding-inline: 9%;
      padding-top: 0.875rem;                  /* room for the "Most popular" badge */
      padding-bottom: 0.5rem;
      scrollbar-width: none;
    }
    .pricing-grid::-webkit-scrollbar { display: none; }
    .price-card {
      flex: 0 0 82%;
      scroll-snap-align: center;
    }
    .price-card--featured { transform: none; }
    .price-card--featured:hover { transform: translateY(-2px); }
    .care-plan { flex-direction: column; align-items: flex-start; }
    .care-right { text-align: left; }

    .pricing-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 2;
      width: 40px;
      height: 40px;
      border-radius: 999px;
      border: 1px solid var(--site-border);
      background: var(--site-bg);
      color: var(--site-fg);
      box-shadow: var(--shadow-md);
      cursor: pointer;
      transition: background 150ms, color 150ms, opacity 150ms;
    }
    .pricing-arrow:hover { background: var(--site-surface); }
    .pricing-arrow--prev { left: 0; }
    .pricing-arrow--next { right: 0; }
    .pricing-arrow[disabled] {
      opacity: 0;
      pointer-events: none;
    }
  }
  @media (max-width: 380px) {
    .pricing-arrow { width: 34px; height: 34px; }
  }

  /* Carousel dots (mobile only) */
  .pricing-dots { display: none; }
  @media (max-width: 860px) {
    .pricing-dots {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 1rem;
    }
    .pricing-dot {
      width: 8px;
      height: 8px;
      padding: 0;
      border: none;
      border-radius: 999px;
      background: var(--site-border);
      cursor: pointer;
      transition: background 200ms, width 200ms;
    }
    .pricing-dot[data-active] {
      background: var(--site-accent);
      width: 22px;
    }
  }
  @media (max-width: 520px) {
    .pricing-header { margin-bottom: 2rem; }
    .price-card { padding: 1.5rem 1.375rem; gap: 0.875rem; }
    .price-value { font-size: 2rem; }
    .price-desc { min-height: 0; }
    .care-plan { padding: 1.25rem; }
  }
</style>

<script>
  const grid = document.getElementById('services')?.querySelector('.pricing-grid') as HTMLElement | null;
  const dotsWrap = document.getElementById('pricing-dots');
  const prevBtn = document.getElementById('pricing-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('pricing-next') as HTMLButtonElement | null;
  if (grid && dotsWrap) {
    const dots = Array.from(dotsWrap.querySelectorAll<HTMLButtonElement>('.pricing-dot'));
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.price-card'));

    const currentIndex = () => {
      const mid = grid.scrollLeft + grid.clientWidth / 2;
      let best = 0, bestDist = Infinity;
      cards.forEach((c, i) => {
        const center = c.offsetLeft + c.offsetWidth / 2;
        const d = Math.abs(center - mid);
        if (d < bestDist) { bestDist = d; best = i; }
      });
      return best;
    };

    // Scroll only the carousel (never the page) to center the given card.
    const goTo = (i: number) => {
      const c = cards[Math.max(0, Math.min(cards.length - 1, i))];
      const left = c.offsetLeft + c.offsetWidth / 2 - grid.clientWidth / 2;
      grid.scrollTo({ left, behavior: 'smooth' });
    };

    const sync = () => {
      const best = currentIndex();
      dots.forEach((d, i) => d.toggleAttribute('data-active', i === best));
      if (prevBtn) prevBtn.disabled = best === 0;
      if (nextBtn) nextBtn.disabled = best === cards.length - 1;
    };

    let raf = 0;
    grid.addEventListener('scroll', () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(sync);
    }, { passive: true });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => goTo(i));
    });
    prevBtn?.addEventListener('click', () => goTo(currentIndex() - 1));
    nextBtn?.addEventListener('click', () => goTo(currentIndex() + 1));

    // On mobile, start centered on the "Most popular" plan.
    const startCarousel = () => {
      // Only when the grid is actually a horizontal carousel (mobile).
      if (grid.scrollWidth <= grid.clientWidth + 4) return;
      let featured = cards.findIndex((c) => c.classList.contains('price-card--featured'));
      if (featured < 0) featured = 0;
      const c = cards[featured];
      // Set scrollLeft directly (no smooth) so it's already there on load,
      // without scrolling the page to the section.
      grid.scrollLeft = c.offsetLeft + c.offsetWidth / 2 - grid.clientWidth / 2;
      sync();
    };

    requestAnimationFrame(startCarousel);
    sync();
  }
</script>
