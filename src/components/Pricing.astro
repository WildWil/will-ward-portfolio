---
const tiers = [
  {
    name: 'Starter',
    price: '$299',
    note: 'one-time',
    desc: 'A clean, professional presence for a new business.',
    features: ['3 pages (Home, About, Contact)', 'Mobile-friendly design', 'Contact info + Google Maps', 'Ready in about 1 week'],
    featured: false,
  },
  {
    name: 'Standard',
    price: '$549',
    note: 'one-time',
    desc: 'More room for services, photos, and getting found on Google.',
    features: ['Up to 5 pages', 'Contact form', 'Photo gallery', 'Basic SEO setup', 'Ready in 1–2 weeks'],
    featured: true,
  },
  {
    name: 'Custom',
    price: '$899+',
    note: 'starting at',
    desc: 'Booking, online store, or custom features built to fit.',
    features: ['Unlimited pages', 'Online booking or store', 'Custom functionality', 'Priority support'],
    featured: false,
  },
];
---
<section class="section pricing-section" id="services">
  <div class="container">
    <div class="pricing-header">
      <span class="section-label">Website Design</span>
      <h2 class="section-heading">Simple pricing. No surprises.</h2>
      <p class="section-sub">
        Flat rates with one revision included and 50% upfront. You own everything when it's done.
      </p>
    </div>

    <div class="pricing-grid">
      {tiers.map(t => (
        <div class={`price-card ${t.featured ? 'price-card--featured' : ''}`}>
          {t.featured && <div class="price-badge">Most popular</div>}
          <div class="price-name">{t.name}</div>
          <div class="price-amount">
            <span class="price-value">{t.price}</span>
            <span class="price-note">{t.note}</span>
          </div>
          <p class="price-desc">{t.desc}</p>
          <ul class="price-features">
            {t.features.map(f => (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="#contact" class={`btn ${t.featured ? 'btn-primary' : 'btn-outline'} price-cta`}>
            Get started
          </a>
        </div>
      ))}
    </div>

    <div class="care-plan">
      <div class="care-left">
        <span class="care-title">Care Plan</span>
        <span class="care-desc">Domain, SSL, small content updates, and ongoing maintenance after launch.</span>
      </div>
      <div class="care-right">
        <span class="care-price">$30<span class="care-per">/mo</span></span>
        <span class="care-optional">optional add-on</span>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    background: var(--site-surface);
    border-top: 1px solid var(--site-border);
    border-bottom: 1px solid var(--site-border);
  }
  .pricing-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .pricing-header .section-sub { text-align: center; }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    align-items: stretch;
    max-width: 980px;
    margin-inline: auto;
  }
  .price-card {
    position: relative;
    background: var(--site-bg);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 200ms, transform 200ms;
  }
  .price-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .price-card--featured {
    background: var(--site-fg);
    border-color: var(--site-fg);
    transform: scale(1.03);
  }
  :global(.dark) .price-card--featured {
    background: #0E2236;
    border-color: var(--primary);
  }
  :global(.dark) .price-card--featured .price-cta {
    background: #0284C7;
    color: #fff;
    border-color: #0284C7;
  }
  :global(.dark) .price-card--featured .price-cta:hover {
    background: #0EA5E9;
    border-color: #0EA5E9;
  }
  .price-card--featured:hover { transform: scale(1.03) translateY(-2px); }
  .price-card--featured .price-name { color: rgba(255,255,255,0.6); }
  .price-card--featured .price-value { color: #fff; }
  .price-card--featured .price-note,
  .price-card--featured .price-desc { color: rgba(255,255,255,0.65); }
  .price-card--featured .price-features li { color: rgba(255,255,255,0.8); }

  .price-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--site-accent);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.875rem;
    border-radius: 999px;
    white-space: nowrap;
  }
  .price-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--site-secondary);
    letter-spacing: 0.02em;
  }
  .price-amount {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .price-value {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--site-fg);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .price-note {
    font-size: 0.8125rem;
    color: var(--site-muted);
  }
  .price-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--site-secondary);
    max-width: 100%;
    min-height: 2.5rem;
  }
  .price-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }
  .price-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--site-secondary);
  }
  .price-features svg {
    flex-shrink: 0;
    color: #22c55e;
    margin-top: 1px;
  }
  .price-card--featured .price-features svg { color: #4ade80; }
  .price-cta {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .price-card--featured .price-cta {
    background: #fff;
    color: var(--site-fg);
    border-color: #fff;
  }
  .price-card--featured .price-cta:hover {
    background: #f1f5f9;
    border-color: #f1f5f9;
  }

  /* Care plan add-on */
  .care-plan {
    max-width: 980px;
    margin: 1.25rem auto 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1.25rem 1.75rem;
    background: var(--site-bg);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-lg);
  }
  .care-left { display: flex; flex-direction: column; gap: 0.2rem; }
  .care-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    color: var(--site-fg);
  }
  .care-desc { font-size: 0.875rem; color: var(--site-secondary); }
  .care-right { text-align: right; }
  .care-price {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--site-fg);
    letter-spacing: -0.02em;
  }
  .care-per { font-size: 0.9rem; color: var(--site-muted); font-weight: 500; }
  .care-optional {
    display: block;
    font-size: 0.75rem;
    color: var(--site-muted);
  }

  @media (max-width: 860px) {
    /* Horizontal swipe carousel: plans side by side, snap as you swipe */
    .pricing-grid {
      display: flex;
      max-width: none;
      gap: 1rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-top: 0.875rem;      /* room for the "Most popular" badge */
      padding-bottom: 1rem;
      scroll-padding-inline: var(--px);
      scrollbar-width: none;
    }
    .pricing-grid::-webkit-scrollbar { display: none; }
    .price-card {
      flex: 0 0 80%;
      scroll-snap-align: start;
    }
    .price-card--featured { transform: none; }
    .price-card--featured:hover { transform: translateY(-2px); }
    .care-plan { flex-direction: column; align-items: flex-start; }
    .care-right { text-align: left; }
  }
  @media (max-width: 520px) {
    .pricing-header { margin-bottom: 2rem; }
    .price-card { padding: 1.5rem 1.375rem; gap: 0.875rem; }
    .price-value { font-size: 2rem; }
    .price-desc { min-height: 0; }
    .care-plan { padding: 1.25rem; }
  }
</style>
