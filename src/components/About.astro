---
---
<section class="section about-section" id="about">
  <div class="container about-inner">
    <div class="about-avatar">
      <div class="avatar-ring">
        <img
          src="/PFP.webp"
          alt="Will Ward"
          class="avatar-photo"
          width="90"
          height="90"
          loading="lazy"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="avatar-initials" style="display:none">WW</div>
      </div>
      <div class="avatar-location">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z" fill="currentColor"/>
        </svg>
        Mount Pleasant, SC
      </div>
    </div>
    <div class="about-content">
      <span class="section-label">About</span>
      <h2 class="section-heading">Web design and IT help in Mount Pleasant.</h2>
      <p class="about-p">
        I'm Will Ward. I build websites for local businesses and handle computer
        repair and upgrades for people in Mount Pleasant, Dunes West, and Park West.
        Been doing this since 2023.
      </p>
      <p class="about-p">
        Every site is custom-coded. No Wix, no templates. For IT work, I give you
        a straight answer on what's wrong and what it'll cost before I touch anything.
      </p>
      <div class="about-skills">
        {['Web Design', 'Computer Repair', 'Astro', 'Cloudflare', 'Hardware Upgrades', 'Remote Support'].map(s => (
          <span class="skill-chip">{s}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    background: var(--site-surface);
    border-top: 1px solid var(--site-border);
    border-bottom: 1px solid var(--site-border);
  }
  .about-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── Avatar ── */
  .about-avatar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    position: sticky;
    top: 90px;
  }
  .avatar-ring {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 2px solid var(--site-border);
    padding: 3px;
    background: var(--site-bg);
    overflow: hidden;
  }
  .avatar-photo {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }
  .avatar-initials {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, #0F172A 0%, #1e3a5f 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.04em;
  }
  .avatar-location {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--site-muted);
    white-space: nowrap;
  }

  /* ── Content ── */
  .about-p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--site-secondary);
    max-width: 58ch;
    margin-bottom: 0.875rem;
  }
  .about-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .skill-chip {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--site-secondary);
    background: var(--site-bg);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-sm);
    padding: 0.3rem 0.75rem;
  }

  @media (max-width: 680px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .about-avatar {
      flex-direction: row;
      position: static;
    }
  }
</style>
